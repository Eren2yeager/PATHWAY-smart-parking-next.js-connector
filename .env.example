# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/smart-parking
# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-this-in-production
NODE_ENV=development
# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id  
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (for password reset OTP)
# Example for Gmail:
# EMAIL_SERVER_HOST=smtp.gmail.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your-email@gmail.com
# EMAIL_SERVER_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yourapp.com
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=
# Python Backend Configuration

NEXT_PUBLIC_PYTHON_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_PYTHON_BACKEND_WS_URL=ws://localhost:8000

# Pathway Webhook Secret (must match PATHWAY_WEBHOOK_SECRET in pathway-work/.env)
PATHWAY_WEBHOOK_SECRET=pw-smart-parking-secret-change-in-prod
